      "regex": "^/api/classroom\\-media/([^/]+?)/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPclassroomId": "nxtPclassroomId",
        "nxtPpath": "nxtPpath"
      },
      "namedRegex": "^/api/classroom\\-media/(?<nxtPclassroomId>[^/]+?)/(?<nxtPpath>.+?)(?:/)?$"
    },
    {
